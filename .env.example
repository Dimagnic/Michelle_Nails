VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- WhatsApp Business ---
# Formato: código de país + número (sin + ni espacios)
# Ejemplo México CDMX: 5215512345678
# Ejemplo México Puebla: 5222XXXXXXXX
VITE_WHATSAPP_NUMBER=52222XXXXXXXX
